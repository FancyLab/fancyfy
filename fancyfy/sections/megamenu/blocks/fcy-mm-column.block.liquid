{% comment %}
  fcy-mm-column — a column of links inside a megamenu panel.
  Heading (optional link) + linklist.
{% endcomment %}
{%- liquid
  assign heading_text = block.settings.heading
  assign heading_link = block.settings.heading_link
  assign sublinks = linklists[block.settings.menu]
-%}
<div class="fcy-mm__column" {{ block.shopify_attributes }}>
  {%- if heading_text != blank -%}
    {%- if heading_link != blank -%}
      <a class="fcy-mm__column-heading fcy-mm__column-heading--link" href="{{ heading_link }}">
        <span>{{ heading_text }}</span>
        <svg class="fcy-mm__column-heading-chevron" aria-hidden="true" width="8" height="12" viewBox="0 0 8 12" fill="none">
          <path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </a>
    {%- else -%}
      <h3 class="fcy-mm__column-heading">{{ heading_text }}</h3>
    {%- endif -%}
  {%- endif -%}
  {%- if sublinks != blank and sublinks.links.size > 0 -%}
    <ul class="fcy-mm__column-links">
      {%- for sublink in sublinks.links -%}
        <li>
          <a
            class="fcy-mm__column-link{% if sublink.active %} is-active{% endif %}"
            href="{{ sublink.url }}"
            {% if sublink.active %}aria-current="page"{% endif %}
          >
            {{ sublink.title }}
          </a>
        </li>
      {%- endfor -%}
    </ul>
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Column",
  "settings": [
    { "type": "text", "id": "heading", "label": "Column heading", "default": "Shop by category" },
    { "type": "url", "id": "heading_link", "label": "Heading link (optional)", "info": "If set, the heading renders as a clickable link." },
    { "type": "link_list", "id": "menu", "label": "Sub-menu", "info": "The linklist whose items are rendered as the column's links." }
  ]
}
{% endschema %}
