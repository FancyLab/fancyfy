{% comment %}
  fcy-mm-promo — an image-card promo inside a megamenu panel.
  Desktop-only visible (CSS hides on mobile per F1 decision).
{% endcomment %}
{%- liquid
  assign image = block.settings.image
  assign heading = block.settings.heading
  assign cta_text = block.settings.cta_text
  assign cta_link = block.settings.cta_link
  assign aspect = block.settings.aspect_ratio
  assign span = block.settings.span
-%}
<a
  class="fcy-mm__promo fcy-mm__promo--ratio-{{ aspect }} fcy-mm__promo--span-{{ span }}"
  href="{{ cta_link | default: '#' }}"
  {{ block.shopify_attributes }}
  style="--fcy-mm-promo-span: {{ span }};"
>
  {%- if image != blank -%}
    <div class="fcy-mm__promo-image">
      {{
        image
        | image_url: width: 800
        | image_tag:
          loading: 'lazy',
          width: image.width,
          height: image.height,
          sizes: '(min-width: 64em) 400px, 100vw',
          widths: '200, 400, 600, 800',
          class: 'fcy-mm__promo-img'
      }}
    </div>
  {%- else -%}
    <div class="fcy-mm__promo-image fcy-mm__promo-image--placeholder" aria-hidden="true"></div>
  {%- endif -%}
  {%- if heading != blank -%}
    <div class="fcy-mm__promo-body">
      <span class="fcy-mm__promo-heading">{{ heading }}</span>
      {%- if cta_text != blank -%}
        <span class="fcy-mm__promo-cta">
          {{ cta_text }}
          <svg aria-hidden="true" width="8" height="12" viewBox="0 0 8 12" fill="none">
            <path d="M1 1l5 5-5 5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </span>
      {%- endif -%}
    </div>
  {%- endif -%}
</a>

{% schema %}
{
  "name": "Promo card",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Aspect ratio",
      "options": [
        { "value": "square", "label": "Square (1:1)" },
        { "value": "portrait", "label": "Portrait (4:5)" },
        { "value": "landscape", "label": "Landscape (16:9)" },
        { "value": "wide", "label": "Wide (2:1)" }
      ],
      "default": "landscape"
    },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "cta_text", "label": "Link text", "default": "Shop now" },
    { "type": "url", "id": "cta_link", "label": "Link URL" },
    {
      "type": "select",
      "id": "span",
      "label": "Column span",
      "info": "How many grid columns this promo occupies.",
      "options": [
        { "value": "1", "label": "1 column" },
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ],
      "default": "1"
    }
  ]
}
{% endschema %}
